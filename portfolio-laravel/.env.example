APP_NAME=Portfolio
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# For Docker development, use these values:
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio
DB_PASSWORD=secret

# For local development without Docker, use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=portfolio
# DB_USERNAME=root
# DB_PASSWORD=your_password

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# Cache Configuration
CACHE_STORE=file
CACHE_PREFIX=

# Queue Configuration
QUEUE_CONNECTION=sync

# Broadcast Configuration
BROADCAST_CONNECTION=log

# Filesystem Configuration
FILESYSTEM_DISK=local

# CORS Configuration (for API)
CORS_PATHS=api/*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8443

# Mail Configuration (for development)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@portfolio.local"
MAIL_FROM_NAME="${APP_NAME}"

# Production Environment Variables (uncomment and configure for production)
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
# DB_PASSWORD=your_secure_production_password
# SESSION_DOMAIN=yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# MAIL_MAILER=smtp
# MAIL_HOST=your-smtp-host
# MAIL_PORT=587
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password
# MAIL_ENCRYPTION=tls
